   "outputs": [],
   "source": [
    "# now define the model as a class\n",
    "class my_cnn(MyClassificationBase):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        \n",
    "        self.cnn_net = nn.Sequential(\n",
    "            \n",
    "        nn.Conv2d(3, 6, kernel_size=3, padding=1),    # in_channels=3 (RGB image), out_channels=16(optional-here we increased the channels from 3 to 16) , kernel_size=3(3*3 filter)\n",
    "        nn.SELU(),                                         #activation layer(Exponential Linear Unit)\n",
    "        nn.BatchNorm2d(6),\n",
    "        # output size: ((224-3+2)/1)+1 = 224  \n",
    "            \n",
    "        nn.Conv2d(6, 16, kernel_size=3, padding=1),    # in_channels=16 (output of previous layer), out_channels=16(optional-here we increased the channels from 3 to 16) , kernel_size=3(3*3 filter)\n",
    "        nn.SELU(),                                         #activation layer(Exponential Linear Unit)\n",
    "        nn.BatchNorm2d(16),\n",
    "        #output size: ((224-3+2)/1)+1 = 224 \n",
    "       \n",
    "        nn.MaxPool2d(kernel_size=2, stride=2),                               #maxpooling filter \n",
    "        #output size:  ((224-2+0)/2)+1 = 112     \n",
    "               \n",
    "        nn.Conv2d(16, 16, kernel_size=3, padding=1),    # in_channels=16 (output of previous layer), out_channels=16(optional-here we increased the channels from 3 to 16) , kernel_size=3(3*3 filter)\n",
    "        nn.SELU(),                                         #activation layer(Exponential Linear Unit)\n",
    "        nn.BatchNorm2d(16),\n",
    "        #output size: ((112-3+2)/1)+1 = 112 \n",
    "             \n",
    "        nn.Flatten(),                                    # Flattens a contiguous range of dims into a tensor\n",
    "        \n",
    "        nn.Linear(16*112*112, 120),                #input is the output of last layer: 110*16(number of channels)\n",
    "        nn.Dropout(0.5),\n",
    "        nn.Linear(120, 84), \n",
    "        nn.Dropout(0.5),\n",
    "        nn.Linear(84, 2)                                 # the final output is batch_size*2 because we have 2 classes\n",
    "            \n",
    "        )\n",
    "        \n",
    "        self.initialization_linear()               # initialize the linear layers weights\n",
    "    \n",
    "    # he weight initialization method\n",
    "    def initialization_linear(self):\n",
    "        for layer in self.cnn_net:\n",
    "            if isinstance(layer, nn.Linear):    #for linear layers     \n",
    "                nn.init.kaiming_uniform_(layer.weight, nonlinearity='relu')    # use he method to initialize weights\n",
    "        \n",
    "    def forward(self, x):       \n",
    "        out = self.cnn_net(x) \n",
    "\n",
    "        return out      "
   ]
  },
