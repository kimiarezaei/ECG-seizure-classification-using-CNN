   "source": [
    "# Define a Convolutional Neural Network"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "55d5e92f-2586-4088-bc96-6d6c8e5f84bb",
   "metadata": {},
   "outputs": [],
   "source": [
    "#model for classification(neural network)\n",
    "class MyClassificationBase(nn.Module):\n",
    "\n",
    "    def training_step(self, batch):\n",
    "        images, labels = batch\n",
    "        images, labels = images.to(device), labels.to(device)\n",
    "        out = self(images)                  #model prediction for training data\n",
    "        loss = F.cross_entropy(out,labels)        # calaculate the loss\n",
    "        return loss\n",
    "        \n",
    "    def validation_step(self, batch):\n",
    "        images, labels = batch\n",
    "        images, labels = images.to(device), labels.to(device)\n",
    "        out = self(images)                            #model prediction for validation data\n",
    "        loss = F.cross_entropy(out,labels)              # calaculate the loss\n",
    "        acc = my_accuracy(out, labels)                  #validation accuracy\n",
    "        return  {'val_loss': loss.detach(), 'val_acc': acc}    #using detach cause the losses are stacked further in fit function\n",
    "        \n",
    "        \n",
    "    def validation_epoch_end(self,outputs):\n",
    "        batch_losses = [x['val_loss'] for x in outputs]\n",
    "        epoch_loss = torch.stack(batch_losses).mean()   # Combine losses\n",
    "        batch_accs = [x['val_acc'] for x in outputs]\n",
    "        epoch_acc = torch.stack(batch_accs).mean()      # Combine accuracies\n",
    "        return {'val_loss': epoch_loss.item(), 'val_acc': epoch_acc.item()}\n",
    "    \n",
    "    def epoch_end(self, ep, result):\n",
    "        print(\"Epoch [{}], train_loss: {:.4f}, val_loss: {:.4f}, val_acc: {:.4f}\".format(ep, result['train_loss'], result['val_loss'], result['val_acc']))\n",
    "                     "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "0e6c884d-7d05-4773-a3bf-a40ce4db072f",
   "metadata": {},
   "outputs": [],
   "source": [
    "#define accuracy fuction\n",
    "def my_accuracy(my_pred, my_label):\n",
    "    _ , soft_pred = torch.max(my_pred, dim=1)     # use soft max for prediction\n",
    "    result = torch.tensor(torch.sum(soft_pred == my_label).item() / len(soft_pred))  # accuracy\n",
    "    return result"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "8b6e59b5-f74e-4ea0-be16-362b5c72c5e0",
   "metadata": {},
   "outputs": [
